rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function approved(userId) {
      return request.auth != null
        && request.auth.uid == userId
        && firestore.exists(
          /databases/(default)/documents/approvedUsers/$(userId)
        )
        && firestore.get(
          /databases/(default)/documents/approvedUsers/$(userId)
        ).data.enabled == true;
    }

    function validImageWrite() {
      return request.resource == null
        || (
          request.resource.size <= 2 * 1024 * 1024
          && request.resource.contentType.matches('image/.*')
        );
    }

    match /users/{userId}/images/{imageType}/{imageKey} {
      allow read: if approved(userId);
      allow write: if approved(userId) && validImageWrite();
    }

    match /users/{userId}/{allPaths=**} {
      allow read, write: if false;
    }
  }
}
